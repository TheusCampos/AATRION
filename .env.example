# =============================================================
# CVForge — Variáveis de Ambiente (exemplo)
# Copie este arquivo para `.env.local` e preencha os valores.
# Nunca commite segredos reais no repositório.
# =============================================================

# ---------- Aplicação ----------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CVForge

# ---------- Banco de Dados ----------
# Em desenvolvimento: SQLite local (arquivo em prisma/dev.db)
# Em produção: trocar para "postgresql://..." e ajustar prisma/schema.prisma provider
DATABASE_URL="file:./dev.db"

# Quando migrar para Postgres, descomentar:
# DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/cvforge?sslmode=require
# DIRECT_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/cvforge?sslmode=require

# ---------- Autenticação (JWT em cookie httpOnly) ----------
# Gere com: openssl rand -hex 32
AUTH_SECRET=troque-por-um-segredo-aleatorio-de-32-bytes-em-hex-64-chars-aaaa

# OAuth Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Cache e Rate Limit (Upstash Redis) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Storage (Cloudflare R2 / S3) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cvforge-uploads
R2_PUBLIC_URL=https://r2.cvforge.com.br
R2_BACKUP_BUCKET=cvforge-backups

# ---------- IA (OpenAI) ----------
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_PREMIUM=gpt-4o

# ---------- Pagamentos (Stripe) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=

# ---------- Email (Resend) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@cvforge.com.br
RESEND_SUPPORT_EMAIL=suporte@cvforge.com.br
RESEND_PRIVACY_EMAIL=privacy@cvforge.com.br

# ---------- Puppeteer / PDF Worker (Fly.io) ----------
PUPPETEER_WORKER_URL=http://localhost:8080
PUPPETEER_API_KEY=

# ---------- LinkedIn Scraping (Proxycurl - V2) ----------
PROXYCURL_API_KEY=

# ---------- Segurança ----------
# Chave AES-256 (32 bytes em hex = 64 caracteres)
ENCRYPTION_KEY=

# ---------- Monitoramento ----------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---------- Anti-bot (Cloudflare Turnstile) ----------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------- Analytics ----------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
